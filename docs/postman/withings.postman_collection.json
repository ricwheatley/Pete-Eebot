        {
          "name": "Raw GetMeas - All Measures (Use This)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test('Withings status is 0', function () {",
                  "  pm.expect(data.status).to.eql(0);",
                  "});",
                  "",
                  "const handled = {",
                  "  '1': 'weight_kg',",
                  "  '5': 'fat_free_mass_kg',",
                  "  '6': 'fat_percent',",
                  "  '8': 'fat_mass_kg',",
                  "  '76': 'muscle_mass_kg',",
                  "  '77': 'water_mass_kg',",
                  "  '88': 'bone_mass_kg',",
                  "  '167': 'nerve_health_score_feet',",
                  "  '170': 'visceral_fat_index',",
                  "  '226': 'bmr_kcal_day'",
                  "};",
                  "const groups = (((data || {}).body || {}).measuregrps || []);",
                  "const counts = {};",
                  "groups.forEach(group => {",
                  "  (group.measures || []).forEach(measure => {",
                  "    const typeId = String(measure.type);",
                  "    counts[typeId] = (counts[typeId] || 0) + 1;",
                  "  });",
                  "});",
                  "const seen = Object.keys(counts).sort((a, b) => Number(a) - Number(b));",
                  "const unhandled = seen.filter(typeId => !handled[typeId]);",
                  "pm.environment.set('measure_type_counts', JSON.stringify(counts));",
                  "pm.environment.set('unhandled_measure_types_seen', unhandled.join(','));",
                  "console.log('Withings measure type counts', counts);",
                  "console.log('Pete-E unhandled measure type IDs', unhandled);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{withings_access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{withings_base_url}}/measure?action=getmeas&category=1&startdate={{target_start_unix}}&enddate={{target_end_unix}}",
              "host": [
                "{{withings_base_url}}"
              ],
              "path": [
                "measure"
              ],
              "query": [
                {
                  "key": "action",
                  "value": "getmeas"
                },
                {
                  "key": "category",
                  "value": "1"
                },
                {
                  "key": "startdate",
                  "value": "{{target_start_unix}}"
                },
                {
                  "key": "enddate",
                  "value": "{{target_end_unix}}"
                }
              ]
            },
            "description": "Raw Withings measure response with no meastypes filter. This is the request to use when checking whether a new scale emits extra measurement type IDs. Set days_back in the environment; the collection pre-request script computes the target UTC day window. The Tests tab stores measure_type_counts and unhandled_measure_types_seen in the environment and logs both to the Postman Console."
          },
          "response": []
        },
