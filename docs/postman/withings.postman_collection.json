{
  "info": {
    "_postman_id": "944d1dbf-ebaf-4f69-8f6b-c8b4bc8aa4cd",
    "name": "Pete-E Withings API",
    "description": "Withings OAuth and measure requests configured to match Pete-E's Withings client. Fill the Pete-E Withings environment from .env and the local token file before sending requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const now = Math.floor(Date.now() / 1000);",
          "pm.environment.set('now_unix', String(now));",
          "pm.environment.set('one_day_ago_unix', String(now - 86400));",
          "",
          "const daysBackRaw = pm.environment.get('days_back') || '1';",
          "const daysBack = Number.parseInt(daysBackRaw, 10);",
          "const safeDaysBack = Number.isFinite(daysBack) ? daysBack : 1;",
          "const target = new Date();",
          "target.setUTCDate(target.getUTCDate() - safeDaysBack);",
          "const start = Date.UTC(target.getUTCFullYear(), target.getUTCMonth(), target.getUTCDate()) / 1000;",
          "pm.environment.set('target_start_unix', String(Math.floor(start)));",
          "pm.environment.set('target_end_unix', String(Math.floor(start + 86400)));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "OAuth",
      "item": [
        {
          "name": "1. Open Authorize URL In Browser (HTML Expected)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{withings_auth_base_url}}/oauth2_user/authorize2?response_type=code&client_id={{withings_client_id}}&redirect_uri={{withings_redirect_uri}}&scope={{withings_scope}}&state={{withings_state}}",
              "host": [
                "{{withings_auth_base_url}}"
              ],
              "path": [
                "oauth2_user",
                "authorize2"
              ],
              "query": [
                {
                  "key": "response_type",
                  "value": "code"
                },
                {
                  "key": "client_id",
                  "value": "{{withings_client_id}}"
                },
                {
                  "key": "redirect_uri",
                  "value": "{{withings_redirect_uri}}"
                },
                {
                  "key": "scope",
                  "value": "{{withings_scope}}"
                },
                {
                  "key": "state",
                  "value": "{{withings_state}}"
                }
              ]
            },
            "description": "This endpoint returns the Withings login/consent HTML page. Do not expect JSON from this request. Copy the full request URL into a normal browser, log in, approve the app, then copy the code query parameter from the redirect URL into withings_authorization_code."
          },
          "response": []
        },
        {
          "name": "2. Exchange Authorization Code",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test('Withings status is 0', function () {",
                  "  pm.expect(data.status).to.eql(0);",
                  "});",
                  "",
                  "if (data.status === 0 && data.body) {",
                  "  const body = data.body;",
                  "  if (body.access_token) pm.environment.set('withings_access_token', body.access_token);",
                  "  if (body.refresh_token) pm.environment.set('withings_refresh_token', body.refresh_token);",
                  "  if (body.userid) pm.environment.set('withings_userid', String(body.userid));",
                  "  if (body.expires_in) {",
                  "    const expiresAt = Math.floor(Date.now() / 1000) + Number(body.expires_in);",
                  "    pm.environment.set('withings_access_token_expires_at', String(expiresAt));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "action",
                  "value": "requesttoken",
                  "type": "text"
                },
                {
                  "key": "grant_type",
                  "value": "authorization_code",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{withings_client_id}}",
                  "type": "text"
                },
                {
                  "key": "client_secret",
                  "value": "{{withings_client_secret}}",
                  "type": "text"
                },
                {
                  "key": "code",
                  "value": "{{withings_authorization_code}}",
                  "type": "text"
                },
                {
                  "key": "redirect_uri",
                  "value": "{{withings_redirect_uri}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{withings_base_url}}/v2/oauth2",
              "host": [
                "{{withings_base_url}}"
              ],
              "path": [
                "v2",
                "oauth2"
              ]
            },
            "description": "Matches pete_e.infrastructure.withings_oauth_helper.exchange_code_for_tokens. Test script saves access_token and refresh_token into the selected Postman environment."
          },
          "response": []
